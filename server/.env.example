# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/edtech

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Cloudinary — get these from https://cloudinary.com/console
# Files (images + videos) are stored here instead of local disk
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
FOLDER_NAME=edtech

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Razorpay
RAZORPAY_KEY=your_razorpay_key
RAZORPAY_SECRET=your_razorpay_secret

# Stripe (optional alternative)
STRIPE_SECRET_KEY=your_stripe_secret_key

# CORS
FRONTEND_URL=http://localhost:3000
